<div class="page-title-row">
  <div>
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">
      <span class="issue-type-badge {{issueTypeClass issue.type}}">{{issueTypeLabel issue.type}}</span>
      <span class="issue-status-badge {{issueStatusClass issue.status}}">{{issueStatusLabel issue.status}}</span>
      <span style="font-size:0.82rem;color:var(--text-3)">{{formatDate issue.created_at}}</span>
    </div>
    <h1>{{issue.title}}</h1>
    {{#if issue.description}}<p style="color:var(--text-2);margin-top:4px">{{issue.description}}</p>{{/if}}
  </div>
  <div class="btn-group">
    <button class="btn btn-secondary" data-modal="modal-edit-issue">✎ Edit</button>
    <button class="btn btn-primary" data-modal="modal-new-step">+ Add Debug Step</button>
  </div>
</div>

<!-- Linked Runs -->
{{#if linkedRuns.length}}
<div class="card" style="margin-bottom:20px">
  <div class="card-header"><h3>Linked Test Runs</h3></div>
  <div class="card-body" style="display:flex;gap:10px;flex-wrap:wrap">
    {{#each linkedRuns}}
    <a href="/projects/{{../project.slug}}/repos/{{repo_slug}}/runs/{{id}}"
       style="display:inline-flex;align-items:center;gap:6px;font-size:0.85rem;padding:4px 10px;background:var(--accent-dim);color:var(--accent);border-radius:99px;text-decoration:none">
      ▶ {{name}} <span style="font-size:0.72rem;color:var(--text-3)">{{repo_name}}</span>
    </a>
    {{/each}}
  </div>
</div>
{{/if}}

<!-- Debug Steps -->
<div class="section">
  <div class="section-header">
    <h2>Debug Steps <span class="badge badge-gray" style="margin-left:6px">{{steps.length}}</span></h2>
  </div>

  {{#if steps.length}}
    {{#each steps}}
    <div class="accordion-group" style="margin-bottom:10px">
      <div class="accordion-trigger" role="button" tabindex="0" aria-expanded="false" style="cursor:pointer">
        <span class="accordion-arrow">▼</span>
        <span style="font-size:0.75rem;color:var(--text-3);flex-shrink:0;min-width:20px;font-weight:600">{{add @index 1}}.</span>
        <span class="accordion-title" style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;padding-right:8px">{{title}}</span>
        <span style="display:flex;align-items:center;gap:4px;flex-shrink:0" onclick="event.stopPropagation()">
          <button type="button" class="btn btn-ghost btn-sm" data-modal="modal-edit-step-{{id}}" style="font-size:0.78rem;padding:3px 8px">✎ Edit</button>
          <form action="/projects/{{../project.slug}}/issues/{{../issue.id}}/steps/{{id}}/delete" method="POST" style="display:inline;margin:0">
            <button type="submit" class="btn btn-ghost btn-sm" style="color:var(--red);font-size:0.78rem;padding:3px 8px" data-confirm="Delete this debug step?">✕</button>
          </form>
        </span>
      </div>
      <div class="accordion-body">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:16px">
          {{#if description}}
          <div>
            <div style="font-size:0.75rem;font-weight:700;color:var(--text-3);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:6px">Description</div>
            <div class="rich-content">{{{description}}}</div>
          </div>
          {{/if}}
          {{#if observation}}
          <div>
            <div style="font-size:0.75rem;font-weight:700;color:var(--text-3);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:6px">Observation</div>
            <div class="rich-content">{{{observation}}}</div>
          </div>
          {{/if}}
        </div>
        {{#if code_snippet}}
        <div>
          <div style="font-size:0.75rem;font-weight:700;color:var(--text-3);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:6px">
            Code Snippet
            <span class="badge badge-gray" style="margin-left:6px;text-transform:none">{{code_language}}</span>
          </div>
          <div class="code-block" data-language="{{code_language}}"><pre><code class="language-{{code_language}}">{{code_snippet}}</code></pre></div>
        </div>
        {{/if}}
      </div>
    </div>

    <!-- Edit Step Modal -->
    <div class="modal-overlay" id="modal-edit-step-{{id}}">
      <div class="modal modal-xl">
        <div class="modal-header">
          <h2>Edit Debug Step</h2>
          <button class="modal-close" data-close-modal="modal-edit-step-{{id}}">✕</button>
        </div>
        <form action="/projects/{{../project.slug}}/issues/{{../issue.id}}/steps/{{id}}/edit" method="POST">
          <div class="modal-body">
            <div class="form-group">
              <label class="form-label">Title *</label>
              <input class="form-control" name="title" value="{{title}}" required>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Description</label>
                <div class="rich-editor-wrap">
                  <div class="rich-editor-toolbar">
                    <button type="button" class="toolbar-btn" data-cmd="bold"><b>B</b></button>
                    <button type="button" class="toolbar-btn" data-cmd="italic"><i>I</i></button>
                    <button type="button" class="toolbar-btn" data-cmd="underline"><u>U</u></button>
                    <span class="toolbar-sep"></span>
                    <button type="button" class="toolbar-btn" data-cmd="insertUnorderedList">• List</button>
                    <button type="button" class="toolbar-btn" data-cmd="insertOrderedList">1. List</button>
                    <span class="toolbar-sep"></span>
                    <button type="button" class="toolbar-btn" data-cmd="insertImage">📷</button>
                  </div>
                  <div class="rich-editor" contenteditable="true">{{{description}}}</div>
                  <input type="hidden" name="description" value="{{description}}">
                </div>
              </div>
              <div class="form-group">
                <label class="form-label">Observation</label>
                <div class="rich-editor-wrap">
                  <div class="rich-editor-toolbar">
                    <button type="button" class="toolbar-btn" data-cmd="bold"><b>B</b></button>
                    <button type="button" class="toolbar-btn" data-cmd="italic"><i>I</i></button>
                    <button type="button" class="toolbar-btn" data-cmd="underline"><u>U</u></button>
                    <span class="toolbar-sep"></span>
                    <button type="button" class="toolbar-btn" data-cmd="insertUnorderedList">• List</button>
                    <button type="button" class="toolbar-btn" data-cmd="insertOrderedList">1. List</button>
                    <span class="toolbar-sep"></span>
                    <button type="button" class="toolbar-btn" data-cmd="insertImage">📷</button>
                  </div>
                  <div class="rich-editor" contenteditable="true">{{{observation}}}</div>
                  <input type="hidden" name="observation" value="{{observation}}">
                </div>
              </div>
            </div>
            <div class="form-group">
              <label class="form-label">Code Snippet</label>
              <div style="display:flex;gap:8px;margin-bottom:6px;align-items:center">
                <label style="font-size:0.82rem;color:var(--text-2)">Language:</label>
                <select class="form-control code-lang-select" style="width:160px" data-target="edit-lang-{{id}}">
                  {{#each (codeLanguages)}}
                  <option value="{{value}}" {{#if (eq value ../code_language)}}selected{{/if}}>{{label}}</option>
                  {{/each}}
                </select>
                <input type="hidden" name="code_language" id="edit-lang-{{id}}" value="{{code_language}}">
              </div>
              <div class="code-editor-wrap">
                <textarea class="code-editor" name="code_snippet" data-language="{{code_language}}" spellcheck="false" rows="10">{{code_snippet}}</textarea>
              </div>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-close-modal="modal-edit-step-{{id}}">Cancel</button>
            <button type="submit" class="btn btn-primary">Save Changes</button>
          </div>
        </form>
      </div>
    </div>
    {{/each}}
  {{else}}
  <div class="empty-state">
    <div class="empty-state-icon">🔍</div>
    <h3>No debug steps yet</h3>
    <p>Add debug steps to document your investigation</p>
  </div>
  {{/if}}
</div>

<!-- New Debug Step Modal -->
<div class="modal-overlay" id="modal-new-step">
  <div class="modal modal-xl">
    <div class="modal-header">
      <h2>Add Debug Step</h2>
      <button class="modal-close" data-close-modal="modal-new-step">✕</button>
    </div>
    <form action="/projects/{{project.slug}}/issues/{{issue.id}}/steps" method="POST">
      <div class="modal-body">
        <div class="form-group">
          <label class="form-label">Title *</label>
          <input class="form-control" name="title" placeholder="e.g. Checked network requests in DevTools" required autofocus>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Description</label>
            <div class="rich-editor-wrap">
              <div class="rich-editor-toolbar">
                <button type="button" class="toolbar-btn" data-cmd="bold"><b>B</b></button>
                <button type="button" class="toolbar-btn" data-cmd="italic"><i>I</i></button>
                <button type="button" class="toolbar-btn" data-cmd="underline"><u>U</u></button>
                <span class="toolbar-sep"></span>
                <button type="button" class="toolbar-btn" data-cmd="insertUnorderedList">• List</button>
                <button type="button" class="toolbar-btn" data-cmd="insertOrderedList">1. List</button>
                <span class="toolbar-sep"></span>
                <button type="button" class="toolbar-btn" data-cmd="insertImage">📷</button>
              </div>
              <div class="rich-editor" contenteditable="true"></div>
              <input type="hidden" name="description">
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Observation</label>
            <div class="rich-editor-wrap">
              <div class="rich-editor-toolbar">
                <button type="button" class="toolbar-btn" data-cmd="bold"><b>B</b></button>
                <button type="button" class="toolbar-btn" data-cmd="italic"><i>I</i></button>
                <button type="button" class="toolbar-btn" data-cmd="underline"><u>U</u></button>
                <span class="toolbar-sep"></span>
                <button type="button" class="toolbar-btn" data-cmd="insertUnorderedList">• List</button>
                <button type="button" class="toolbar-btn" data-cmd="insertOrderedList">1. List</button>
                <span class="toolbar-sep"></span>
                <button type="button" class="toolbar-btn" data-cmd="insertImage">📷</button>
              </div>
              <div class="rich-editor" contenteditable="true"></div>
              <input type="hidden" name="observation">
            </div>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Code Snippet</label>
          <div style="display:flex;gap:8px;margin-bottom:6px;align-items:center">
            <label style="font-size:0.82rem;color:var(--text-2)">Language:</label>
            <select class="form-control code-lang-select" style="width:160px" data-target="new-step-lang">
              <option value="javascript">JavaScript</option>
              <option value="typescript">TypeScript</option>
              <option value="python">Python</option>
              <option value="java">Java</option>
              <option value="csharp">C#</option>
              <option value="cpp">C++</option>
              <option value="go">Go</option>
              <option value="rust">Rust</option>
              <option value="php">PHP</option>
              <option value="ruby">Ruby</option>
              <option value="swift">Swift</option>
              <option value="kotlin">Kotlin</option>
              <option value="sql">SQL</option>
              <option value="html">HTML</option>
              <option value="css">CSS</option>
              <option value="bash">Bash</option>
              <option value="json">JSON</option>
              <option value="xml">XML</option>
              <option value="yaml">YAML</option>
              <option value="plaintext">Plain Text</option>
            </select>
            <input type="hidden" name="code_language" id="new-step-lang" value="javascript">
          </div>
          <div class="code-editor-wrap">
            <textarea class="code-editor" name="code_snippet" data-language="javascript" spellcheck="false" rows="10" placeholder="Paste your code here…"></textarea>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-close-modal="modal-new-step">Cancel</button>
        <button type="submit" class="btn btn-primary">Add Step</button>
      </div>
    </form>
  </div>
</div>

<!-- Edit Issue Modal -->
<div class="modal-overlay" id="modal-edit-issue">
  <div class="modal modal-lg">
    <div class="modal-header">
      <h2>Edit Issue</h2>
      <button class="modal-close" data-close-modal="modal-edit-issue">✕</button>
    </div>
    <form action="/projects/{{project.slug}}/issues/{{issue.id}}/edit" method="POST">
      <div class="modal-body">
        <div class="form-group">
          <label class="form-label">Title *</label>
          <input class="form-control" name="title" value="{{issue.title}}" required>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Type</label>
            <select class="form-control" name="type">
              <option value="bug" {{#if (eq issue.type 'bug')}}selected{{/if}}>🐛 Bug</option>
              <option value="feature" {{#if (eq issue.type 'feature')}}selected{{/if}}>✨ Feature</option>
              <option value="improvement" {{#if (eq issue.type 'improvement')}}selected{{/if}}>⚡ Improvement</option>
              <option value="task" {{#if (eq issue.type 'task')}}selected{{/if}}>📋 Task</option>
              <option value="question" {{#if (eq issue.type 'question')}}selected{{/if}}>❓ Question</option>
              <option value="documentation" {{#if (eq issue.type 'documentation')}}selected{{/if}}>📄 Documentation</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Status</label>
            <select class="form-control" name="status">
              <option value="open" {{#if (eq issue.status 'open')}}selected{{/if}}>Open</option>
              <option value="in_progress" {{#if (eq issue.status 'in_progress')}}selected{{/if}}>In Progress</option>
              <option value="resolved" {{#if (eq issue.status 'resolved')}}selected{{/if}}>Resolved</option>
              <option value="closed" {{#if (eq issue.status 'closed')}}selected{{/if}}>Closed</option>
              <option value="wont_fix" {{#if (eq issue.status 'wont_fix')}}selected{{/if}}>Won't Fix</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Description</label>
          <textarea class="form-control" name="description" rows="3">{{issue.description}}</textarea>
        </div>
      </div>
      <div class="modal-footer">
        <form action="/projects/{{project.slug}}/issues/{{issue.id}}/delete" method="POST" style="margin-right:auto">
          <button type="submit" class="btn btn-danger btn-sm" data-confirm="Delete this issue and all debug steps?">Delete Issue</button>
        </form>
        <button type="button" class="btn btn-secondary" data-close-modal="modal-edit-issue">Cancel</button>
        <button type="submit" class="btn btn-primary">Save Changes</button>
      </div>
    </form>
  </div>
</div>

<script>
// Init all rich editors on page load
document.querySelectorAll('.rich-editor-wrap').forEach(wrap => {
  if (typeof initRichEditor === 'function') initRichEditor(wrap);
});

// Code language selector syncs to hidden input
document.querySelectorAll('.code-lang-select').forEach(sel => {
  sel.addEventListener('change', function() {
    const targetId = this.dataset.target;
    const hidden = document.getElementById(targetId);
    if (hidden) hidden.value = this.value;
    // Update textarea data-language for highlighter
    const wrap = this.closest('.modal-body, .form-group').querySelector('.code-editor');
    if (wrap) { wrap.dataset.language = this.value; highlightEditor(wrap); }
  });
});

// Apply Prism highlighting to all code blocks on page
document.querySelectorAll('.code-block code').forEach(block => {
  if (window.Prism) Prism.highlightElement(block);
});

// Live highlight in code editor textareas
function highlightEditor(textarea) {
  // Visual feedback: just update the data attribute; Prism handles display blocks
  // For live editing we use the overlay technique in CSS
}

// Highlight all code editors on open modal
document.querySelectorAll('.code-editor').forEach(ta => {
  ta.addEventListener('input', function() {
    // We can't live-highlight a textarea directly without a library like CodeMirror
    // So we just keep it styled nicely via CSS
  });
});
</script>