<div class="page-title-row">
  <div>
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">
      <span class="status-badge {{run.status}}">{{statusLabel run.status}}</span>
      {{#if run.plan_name}}<span class="badge badge-blue">{{run.plan_name}}</span>{{/if}}
      <span style="font-size:0.82rem;color:var(--text-3)">{{formatDate run.created_at}}</span>
    </div>
    <h1>{{run.name}}</h1>
    {{#if run.description}}<p>{{run.description}}</p>{{/if}}
  </div>
  <div class="btn-group">
    {{#if (eq run.status 'in_progress')}}
    <form action="/projects/{{project.slug}}/repos/{{repo.slug}}/runs/{{run.id}}/status" method="POST" style="display:inline">
      <input type="hidden" name="status" value="completed">
      <button type="submit" class="btn btn-primary" data-confirm="Mark this run as completed?">✔ Complete Run</button>
    </form>
    <form action="/projects/{{project.slug}}/repos/{{repo.slug}}/runs/{{run.id}}/status" method="POST" style="display:inline">
      <input type="hidden" name="status" value="aborted">
      <button type="submit" class="btn btn-secondary" data-confirm="Abort this run?">✕ Abort</button>
    </form>
    {{else}}
    <form action="/projects/{{project.slug}}/repos/{{repo.slug}}/runs/{{run.id}}/status" method="POST" style="display:inline">
      <input type="hidden" name="status" value="in_progress">
      <button type="submit" class="btn btn-secondary">↩ Reopen</button>
    </form>
    {{/if}}
    <form action="/projects/{{project.slug}}/repos/{{repo.slug}}/runs/{{run.id}}/delete" method="POST" style="display:inline">
      <button type="submit" class="btn btn-danger" data-confirm="Delete this run and all results?">Delete</button>
    </form>
  </div>
</div>

<!-- Progress Summary -->
<div class="card" style="margin-bottom:20px">
  <div class="card-body">
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(100px,1fr));gap:16px;margin-bottom:14px">
      <div style="text-align:center">
        <div style="font-size:1.6rem;font-weight:600">{{statusCounts.total}}</div>
        <div style="font-size:0.75rem;color:var(--text-3);text-transform:uppercase;letter-spacing:0.04em">Total</div>
      </div>
      <div style="text-align:center">
        <div style="font-size:1.6rem;font-weight:600;color:var(--green)" class="count-passed">{{statusCounts.passed}}</div>
        <div style="font-size:0.75rem;color:var(--green);text-transform:uppercase;letter-spacing:0.04em">Passed</div>
      </div>
      <div style="text-align:center">
        <div style="font-size:1.6rem;font-weight:600;color:var(--red)" class="count-failed">{{statusCounts.failed}}</div>
        <div style="font-size:0.75rem;color:var(--red);text-transform:uppercase;letter-spacing:0.04em">Failed</div>
      </div>
      <div style="text-align:center">
        <div style="font-size:1.6rem;font-weight:600;color:var(--purple)" class="count-blocked">{{statusCounts.blocked}}</div>
        <div style="font-size:0.75rem;color:var(--purple);text-transform:uppercase;letter-spacing:0.04em">Blocked</div>
      </div>
      <div style="text-align:center">
        <div style="font-size:1.6rem;font-weight:600;color:var(--text-3)" class="count-skipped">{{statusCounts.skipped}}</div>
        <div style="font-size:0.75rem;color:var(--text-3);text-transform:uppercase;letter-spacing:0.04em">Skipped</div>
      </div>
      <div style="text-align:center">
        <div style="font-size:1.6rem;font-weight:600;color:var(--text-3)" class="count-pending">{{statusCounts.pending}}</div>
        <div style="font-size:0.75rem;color:var(--text-3);text-transform:uppercase;letter-spacing:0.04em">Pending</div>
      </div>
    </div>
    <div class="progress-stacked">
      <div class="seg seg-passed" style="width:{{pct statusCounts.passed statusCounts.total}}%"></div>
      <div class="seg seg-failed" style="width:{{pct statusCounts.failed statusCounts.total}}%"></div>
      <div class="seg seg-blocked" style="width:{{pct statusCounts.blocked statusCounts.total}}%"></div>
      <div class="seg seg-skipped" style="width:{{pct statusCounts.skipped statusCounts.total}}%"></div>
      <div class="seg seg-pending" style="width:{{pct statusCounts.pending statusCounts.total}}%"></div>
    </div>
    {{#if (eq run.status 'completed')}}
    <div style="margin-top:10px;font-size:0.82rem;color:var(--text-3)">
      ✔ Completed {{formatDateTime run.completed_at}}
      — Pass rate: <strong style="color:var(--green)">{{pct statusCounts.passed statusCounts.total}}%</strong>
    </div>
    {{/if}}
  </div>
</div>

<!-- Filter bar -->
<div style="display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap;align-items:center">
  <span style="font-size:0.82rem;color:var(--text-3)">Filter:</span>
  <button class="btn btn-sm run-filter active" data-filter="all">All</button>
  <button class="btn btn-sm run-filter" data-filter="pending" style="color:var(--text-3)">Pending</button>
  <button class="btn btn-sm run-filter" data-filter="passed" style="color:var(--green)">Passed</button>
  <button class="btn btn-sm run-filter" data-filter="failed" style="color:var(--red)">Failed</button>
  <button class="btn btn-sm run-filter" data-filter="blocked" style="color:var(--purple)">Blocked</button>
  <button class="btn btn-sm run-filter" data-filter="skipped">Skipped</button>
</div>

<!-- Results -->
<div id="results-list">
{{#each results}}
<div class="run-result-row" data-status="{{status}}">
  <div class="run-result-header">
    <span class="result-arrow" style="color:var(--text-3);font-size:0.7rem;width:14px;flex-shrink:0">▼</span>
    <div style="flex:1;min-width:0">
      <div class="result-title">
        <a href="/projects/{{../project.slug}}/repos/{{../repo.slug}}/cases/{{test_case_id}}" target="_blank" style="color:var(--text)">{{title}}</a>
      </div>
      <div style="display:flex;align-items:center;gap:8px;margin-top:3px;flex-wrap:wrap">
        <span class="priority-badge {{priority}}"><span class="priority-dot {{priority}}"></span>{{capitalize priority}}</span>
        <span class="badge badge-gray" style="font-size:0.72rem">{{typeLabel type}}</span>
        {{#if group_name}}<span class="badge badge-blue" style="font-size:0.72rem">{{group_name}}</span>{{/if}}
        {{#if url}}<a href="{{url}}" target="_blank" style="font-size:0.75rem;color:var(--text-3)">🔗 URL</a>{{/if}}
        <span style="font-size:0.75rem;color:var(--text-3)">{{notes.length}} note{{#if (ne notes.length 1)}}s{{/if}}</span>
      </div>
    </div>
    <div style="display:flex;align-items:center;gap:10px;flex-shrink:0">
      <span class="status-badge result-status-badge {{status}}">{{status}}</span>
      {{#if (eq ../run.status 'in_progress')}}
      <select class="form-control result-status-select"
        data-url="/projects/{{../project.slug}}/repos/{{../repo.slug}}/runs/{{../run.id}}/results/{{id}}/status"
        style="width:auto;padding:4px 8px;font-size:0.82rem"
        onclick="event.stopPropagation()">
        <option value="pending" {{#if (eq status 'pending')}}selected{{/if}}>⬜ Pending</option>
        <option value="passed" {{#if (eq status 'passed')}}selected{{/if}}>✅ Passed</option>
        <option value="failed" {{#if (eq status 'failed')}}selected{{/if}}>❌ Failed</option>
        <option value="blocked" {{#if (eq status 'blocked')}}selected{{/if}}>🚫 Blocked</option>
        <option value="skipped" {{#if (eq status 'skipped')}}selected{{/if}}>⏭ Skipped</option>
      </select>
      {{/if}}
    </div>
  </div>
  <div class="run-result-body">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px">
      {{#if case_description}}
      <div>
        <div style="font-size:0.78rem;font-weight:600;color:var(--text-3);text-transform:uppercase;letter-spacing:0.04em;margin-bottom:5px">Description</div>
        <div style="font-size:0.85rem;color:var(--text-2);line-height:1.6">{{case_description}}</div>
      </div>
      {{/if}}
      {{#if expected_result}}
      <div>
        <div style="font-size:0.78rem;font-weight:600;color:var(--text-3);text-transform:uppercase;letter-spacing:0.04em;margin-bottom:5px">Expected Result</div>
        <div style="font-size:0.85rem;padding:8px;background:var(--green-dim);border-radius:var(--radius);border-left:3px solid var(--green);color:var(--text)">{{expected_result}}</div>
      </div>
      {{/if}}
    </div>

    {{#if steps}}
    <div style="margin-bottom:16px">
      <div style="font-size:0.78rem;font-weight:600;color:var(--text-3);text-transform:uppercase;letter-spacing:0.04em;margin-bottom:8px">Steps</div>
      <div class="steps-raw" style="font-size:0.85rem;line-height:1.8;white-space:pre-line;color:var(--text-2)">{{steps}}</div>
    </div>
    {{/if}}

    <div class="divider"></div>

    <!-- Notes -->
    <div style="margin-bottom:12px">
      <div style="font-size:0.82rem;font-weight:600;color:var(--text-2);margin-bottom:10px">📝 Notes</div>
      <div class="notes-list">
        {{#each notes}}
        <div class="note-card" data-note-id="{{id}}">
          <div class="note-card-header">
            <span class="note-time">{{formatDateTime created_at}}</span>
            {{#if (eq ../../run.status 'in_progress')}}
            <div style="display:flex;gap:4px">
              <button type="button" class="btn btn-ghost btn-sm edit-note-btn" style="font-size:0.78rem">Edit</button>
              <button type="button" class="btn btn-ghost btn-sm delete-note-btn" style="font-size:0.78rem;color:var(--red)"
                data-url="/projects/{{../../../project.slug}}/repos/{{../../../repo.slug}}/runs/{{../../../run.id}}/results/{{../../id}}/notes/{{id}}/delete">✕</button>
            </div>
            {{/if}}
          </div>
          <div class="note-content">{{{content}}}</div>
        </div>
        {{/each}}
      </div>

      {{#if (eq ../run.status 'in_progress')}}
      <div style="margin-top:10px">
        <div style="font-size:0.8rem;color:var(--text-3);margin-bottom:6px">Add a note (supports rich text, images)</div>
        <div class="add-note-form"
          data-url="/projects/{{../project.slug}}/repos/{{../repo.slug}}/runs/{{../run.id}}/results/{{id}}/notes">
          <div class="rich-editor-wrap">
            <div class="rich-editor-toolbar">
              <button type="button" class="toolbar-btn" data-cmd="bold"><b>B</b></button>
              <button type="button" class="toolbar-btn" data-cmd="italic"><i>I</i></button>
              <button type="button" class="toolbar-btn" data-cmd="underline"><u>U</u></button>
              <button type="button" class="toolbar-btn" data-cmd="strikeThrough"><s>S</s></button>
              <span class="toolbar-sep"></span>
              <button type="button" class="toolbar-btn" data-cmd="insertUnorderedList">• List</button>
              <button type="button" class="toolbar-btn" data-cmd="insertOrderedList">1. List</button>
              <span class="toolbar-sep"></span>
              <button type="button" class="toolbar-btn" data-cmd="formatBlock" data-val="blockquote">❝</button>
              <button type="button" class="toolbar-btn" data-cmd="formatBlock" data-val="pre">{ }</button>
              <span class="toolbar-sep"></span>
              <button type="button" class="toolbar-btn" data-cmd="insertImage">📷 Image</button>
              <button type="button" class="toolbar-btn" data-cmd="createLink">🔗 Link</button>
              <span class="toolbar-sep"></span>
              <button type="button" class="toolbar-btn" data-cmd="removeFormat">✕</button>
            </div>
            <div class="rich-editor" contenteditable="true" style="min-height:80px" placeholder="Type your note here… you can paste or drag images"></div>
            <input type="hidden" name="content">
          </div>
          <div style="display:flex;justify-content:flex-end;margin-top:8px">
            <button type="submit" class="btn btn-primary btn-sm">Add Note</button>
          </div>
        </div>
      </div>
      {{/if}}
    </div>
  </div>
</div>
{{else}}
<div class="empty-state">
  <div class="empty-state-icon">🧪</div>
  <h3>No test cases in this run</h3>
</div>
{{/each}}
</div>

<script>
// Filter by status
document.querySelectorAll('.run-filter').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.run-filter').forEach(b => b.classList.remove('active','btn-primary'));
    btn.classList.add('active','btn-primary');
    const f = btn.dataset.filter;
    document.querySelectorAll('.run-result-row').forEach(row => {
      row.style.display = (f === 'all' || row.dataset.status === f) ? '' : 'none';
    });
  });
});

// Parse steps into numbered list
document.querySelectorAll('.steps-raw').forEach(el => {
  const lines = el.textContent.split('\n').map(l => l.replace(/^\d+[\.\)]\s*/, '').trim()).filter(Boolean);
  if (lines.length > 1) {
    const ol = document.createElement('ol');
    ol.className = 'steps-list';
    lines.forEach(l => { const li = document.createElement('li'); li.textContent = l; ol.appendChild(li); });
    el.replaceWith(ol);
  }
});

// Init rich editors for notes
document.querySelectorAll('.add-note-form .rich-editor-wrap').forEach(wrap => {
  initRichEditorInline(wrap);
});

function initRichEditorInline(wrap) {
  const toolbar = wrap.querySelector('.rich-editor-toolbar');
  const editor = wrap.querySelector('.rich-editor');
  const hidden = wrap.querySelector('input[name=content]');
  if (!toolbar || !editor) return;

  toolbar.addEventListener('mousedown', e => {
    e.preventDefault();
    const btn = e.target.closest('.toolbar-btn');
    if (!btn) return;
    const cmd = btn.dataset.cmd, val = btn.dataset.val;
    if (cmd === 'insertImage') triggerImageUpload(editor);
    else if (cmd === 'createLink') { const url = prompt('URL:'); if (url) document.execCommand('createLink', false, url); }
    else document.execCommand(cmd, false, val || null);
    editor.focus();
    if (hidden) hidden.value = editor.innerHTML;
  });

  editor.addEventListener('input', () => { if (hidden) hidden.value = editor.innerHTML; });

  editor.addEventListener('paste', async e => {
    const items = e.clipboardData?.items;
    if (!items) return;
    for (const item of items) {
      if (item.type.startsWith('image/')) {
        e.preventDefault();
        const url = await uploadImage(item.getAsFile());
        if (url) document.execCommand('insertImage', false, url);
        if (hidden) hidden.value = editor.innerHTML;
        break;
      }
    }
  });

  editor.addEventListener('drop', async e => {
    const files = e.dataTransfer?.files;
    if (!files?.length) return;
    for (const f of files) {
      if (f.type.startsWith('image/')) {
        e.preventDefault();
        const url = await uploadImage(f);
        if (url) document.execCommand('insertImage', false, url);
        if (hidden) hidden.value = editor.innerHTML;
      }
    }
  });
}

// Submit note forms
document.addEventListener('click', async e => {
  // Add note
  const addBtn = e.target.closest('.add-note-form button[type=submit]');
  if (addBtn) {
    e.preventDefault();
    const form = addBtn.closest('.add-note-form');
    const editor = form.querySelector('.rich-editor');
    const content = editor.innerHTML.trim();
    if (!content || content === '<br>') { showToast('Note is empty','error'); return; }
    try {
      const r = await fetch(form.dataset.url, {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ content })
      });
      const data = await r.json();
      if (data.ok) {
        const notesList = form.closest('.run-result-body').querySelector('.notes-list');
        const div = document.createElement('div');
        div.className = 'note-card';
        div.dataset.noteId = data.note.id;
        div.innerHTML = `<div class="note-card-header"><span class="note-time">Just now</span><div style="display:flex;gap:4px"><button type="button" class="btn btn-ghost btn-sm edit-note-btn" style="font-size:0.78rem">Edit</button><button type="button" class="btn btn-ghost btn-sm delete-note-btn" style="font-size:0.78rem;color:var(--red)" data-url="${form.dataset.url.replace('/notes','')}/notes/${data.note.id}/delete">✕</button></div></div><div class="note-content">${data.note.content}</div>`;
        notesList.appendChild(div);
        editor.innerHTML = '';
        form.querySelector('input[name=content]').value = '';
        // update note count
        const row = form.closest('.run-result-row');
        const countEl = row?.querySelector('.run-result-header [style*="note"]');
        showToast('Note added','success');
      }
    } catch(err) { showToast('Error saving note','error'); }
    return;
  }

  // Delete note
  const delBtn = e.target.closest('.delete-note-btn');
  if (delBtn) {
    if (!confirm('Delete this note?')) return;
    try {
      const r = await fetch(delBtn.dataset.url, { method:'POST' });
      const data = await r.json();
      if (data.ok) { delBtn.closest('.note-card')?.remove(); showToast('Note deleted'); }
    } catch {}
    return;
  }

  // Edit note (inline)
  const editBtn = e.target.closest('.edit-note-btn');
  if (editBtn) {
    const noteCard = editBtn.closest('.note-card');
    const contentEl = noteCard.querySelector('.note-content');
    const noteId = noteCard.dataset.noteId;
    const resultBody = noteCard.closest('.run-result-body');
    const runResultUrl = resultBody.querySelector('.add-note-form')?.dataset.url;
    if (!runResultUrl) return;
    const editUrl = runResultUrl + '/' + noteId + '/edit';

    if (editBtn.textContent === 'Edit') {
      // Switch to edit mode
      const current = contentEl.innerHTML;
      contentEl.setAttribute('data-original', current);
      contentEl.contentEditable = 'true';
      contentEl.style.border = '1px solid var(--accent)';
      contentEl.style.borderRadius = 'var(--radius)';
      contentEl.style.padding = '6px';
      contentEl.style.outline = 'none';
      contentEl.focus();
      editBtn.textContent = 'Save';
    } else {
      // Save
      const newContent = contentEl.innerHTML;
      try {
        const r = await fetch(editUrl, {
          method:'POST', headers:{'Content-Type':'application/json'},
          body: JSON.stringify({ content: newContent })
        });
        const data = await r.json();
        if (data.ok) {
          contentEl.contentEditable = 'false';
          contentEl.style.border = '';
          contentEl.style.borderRadius = '';
          contentEl.style.padding = '';
          editBtn.textContent = 'Edit';
          showToast('Note updated','success');
        }
      } catch { showToast('Error','error'); }
    }
  }
});
</script>
